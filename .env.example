POSTGRES_DB=name_db
POSTGRES_USER=name_user_name
POSTGRES_PASSWORD=password

DB_HOST=db
DB_PORT=5432

ASPNETCORE_ENVIRONMENT=Development
VITE_API_URL=/api

# Public frontend URL used in email links.
Frontend__BaseUrl=https://localhost

# Yandex SMTP. Use an app password from Yandex ID, not the mailbox password.
Email__FromName=StudPay
Email__FromAddress=your-mail@yandex.ru
Email__Smtp__Host=smtp.yandex.ru
Email__Smtp__Port=587
Email__Smtp__UseSsl=true
Email__Smtp__Username=your-mail@yandex.ru
Email__Smtp__Password=your-yandex-app-password
